#!/bin/sh

ydotool mousemove -a $1 $2 || exit 1
[ -n "$4" ] && ydotool type $4
cp $XDG_CACHE_HOME/dictionary/dictionary$3 /tmp/dictionary || exit 1

case $3 in
	-1) x="14:1 14:0";;
	-2) x="14:1 14:0 14:1 14:0";;
	-3) x="14:1 14:0 14:1 14:0 14:1 14:0";;
esac
until [ "$(wc -l </tmp/dictionary)" = "0" ]; do
	ydotool type $(head -1 /tmp/dictionary)
	sed -i "1d" /tmp/dictionary
	ydotool key 28:1 28:0
	sleep 0.7
	ydotool key $x
done
