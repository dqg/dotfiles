{
  "layer": "top",
  "modules-left": ["custom/logo", "hyprland/workspaces", "custom/weather", "tray"],
  "modules-center": [],
  "modules-right": ["battery", "custom/updates", "pulseaudio", "memory", "network", "clock", "custom/clock"],
  "custom/logo": {
    "tooltip": false,
    "format": " "
  },
  "hyprland/workspaces": {
    "persistent_workspaces": {
      "*": 5
    }
  },
  "custom/weather": {
    "tooltip": false,
    "format": "{}",
    "exec": "sb-weather",
    "on-click": "kitty -e less -RSf $XDG_CACHE_HOME/weather",
    "interval": 1800
  },
  "tray": {
    "icon-size": 20,
    "spacing": 10
  },
  "custom/clock": {
    "tooltip": false,
    "format": "{}",
    "exec": "sb-clock",
    "interval": 60
  },
  "clock": {
    "tooltip-format": "<small>{calendar}</small>",
    "format": "󰃶 {:%b %d %a}",
    "calendar": {
      "mode-mon-col": 3,
      "on-scroll": 1,
      "format": {
        "months": "<span color='#94e2d5'><b>{}</b></span>",
        "weekdays": "<span color='#f9e2af'><b>{}</b></span>",
        "days": "<span color='#cdd6f4'><b>{}</b></span>",
        "today": "<span color='#f38ba8'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    },
    "interval": 3600
  },
  "network": {
    "tooltip": false,
    "format-ethernet": "󰈀 {ipaddr}/{cidr}",
    "format-wifi": "󰖩 ({signalStrength}%) {essid}",
    "format-alt": "󰕒 {bandwidthUpBytes} 󰇚 {bandwidthDownBytes}",
    "interval": 1
  },
  "memory": {
    "tooltip-format": "Memory: {used}G/{total}G\nSwap: {swapUsed}G/{swapTotal}G",
    "format": " {percentage}%",
    "interval": 1
  },
  "pulseaudio": {
    "tooltip-format": "{desc}, {volume}%",
    "format": "{icon} {volume}%",
    "format-muted": "󰖁",
    "format-icons": {
      "default": ["󰕿", "󰖀", "󰕾"]
    },
    "on-click": "pulsemixer --toggle-mute",
    "on-click-right": "pulsemixer --set-volume 100",
    "on-scroll-up": "pulsemixer --change-volume +5",
    "on-scroll-down": "pulsemixer --change-volume -5"
  },
  "custom/updates": {
    "tooltip": false,
    "format": "󰏗 {}",
    "on-click": "kitty -e doas pacman -Su",
    "exec": "pacman -Qu | wc -l",
    "interval": 3600
  },
  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰚥 {capacity}%",
    "format-icons": ["󰂃", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
    "interval": 60
  },
}
